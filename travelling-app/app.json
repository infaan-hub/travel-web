{
  "expo": {
    "name": "Infaan Travel",
    "slug": "travelling-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "infaanTravel",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.infaanhubsteam.infaanTravel",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Infaan Travel to access your photos for profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B5E8A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.infaanhubsteam.infaanTravel"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B5E8A",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "54d2bf44-08c0-4500-b3dd-37fcc0438414"
      }
    },
    "owner": "infaan-hubs-team"
  }
}
